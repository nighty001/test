#!/usr/bin/python3
import json
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs, urlsplit


PAGES = {
    "/view": b'''<!doctype html><html><body style="background:#000;color:#fff;font-size:96px">VIEW &#x1F600; <span id="tick">0</span><script>let n=0;setInterval(()=>document.getElementById("tick").textContent=++n,100);</script></body></html>''',
    "/roundview": b'<!doctype html><html><body style="background:#fff;color:#000;font-size:96px">ROUNDVIEW</body></html>',
}


class Handler(BaseHTTPRequestHandler):
    running = False

    def do_GET(self):
        parsed = urlsplit(self.path)
        if parsed.path == "/selftest/running":
            value = parse_qs(parsed.query).get("value", ["0"])[0]
            Handler.running = value in ("1", "true")
        if parsed.path in ("/status", "/selftest/running"):
            body = json.dumps({"running": Handler.running}).encode("utf-8")
            content_type = "application/json"
        else:
            body = PAGES.get(parsed.path)
            content_type = "text/html; charset=utf-8"
        if body is None:
            self.send_error(404)
            return
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)


if __name__ == "__main__":
    ThreadingHTTPServer(("192.168.4.1", 80), Handler).serve_forever()
