#!/bin/sh
set -u

report() {
  printf '<6>%s\n' "$*" > /dev/kmsg
}

report 'KIOSK_SELFTEST_START'

# Provide a deterministic local stand-in for the ESP32 during the VM test.
ip address add 192.168.4.1/32 dev lo 2>/dev/null || true
install -d -m 0755 /run/kiosk-selftest-web
printf '%s\n' '<!doctype html><html><body style="background:#000;color:#fff;font-size:96px">VIEW</body></html>' \
  > /run/kiosk-selftest-web/view
printf '%s\n' '<!doctype html><html><body style="background:#fff;color:#000;font-size:96px">ROUNDVIEW</body></html>' \
  > /run/kiosk-selftest-web/roundview
python3 -m http.server 80 --bind 192.168.4.1 --directory /run/kiosk-selftest-web \
  >/run/kiosk-selftest-http.log 2>&1 &

mpv_is_running() {
  ps -C mpv -o stat= 2>/dev/null | grep -qv '^[[:space:]]*Z'
}

ready=0
for second in $(seq 1 120); do
  if systemctl is-active --quiet kiosk.service \
    && pgrep -x Xorg >/dev/null \
    && pgrep -u kiosk -f '/usr/lib/chromium/chromium|/usr/lib/chromium/chromium-browser' >/dev/null \
    && pgrep -u kiosk -f '/usr/local/bin/kiosk-media-monitor' >/dev/null \
    && curl -fsS --max-time 1 http://127.0.0.1:9222/json | grep -Fq '192.168.4.1/view'; then
    ready=1
    break
  fi
  if [ $((second % 20)) -eq 0 ]; then
    x=0; chromium=0; monitor=0; cdp=0
    pgrep -x Xorg >/dev/null && x=1
    pgrep -u kiosk -f '/usr/lib/chromium/chromium|/usr/lib/chromium/chromium-browser' >/dev/null && chromium=1
    pgrep -u kiosk -f '/usr/local/bin/kiosk-media-monitor' >/dev/null && monitor=1
    curl -fsS --max-time 1 http://127.0.0.1:9222/json/version >/dev/null && cdp=1
    report "KIOSK_SELFTEST_WAIT second=$second x=$x chromium=$chromium monitor=$monitor cdp=$cdp"
  fi
  if systemctl is-failed --quiet kiosk.service; then
    break
  fi
  sleep 1
done

if [ "$ready" -eq 1 ]; then
  report 'KIOSK_SELFTEST_BROWSER_READY'
  if curl -fsS --max-time 2 http://192.168.4.1/roundview >/dev/null; then
    report 'KIOSK_SELFTEST_ROUNDVIEW_HTTP_READY'
  else
    report 'KIOSK_SELFTEST_ROUNDVIEW_HTTP_FAIL'
  fi
  media_ready=0
  for second in $(seq 1 90); do
    if mpv_is_running; then
      media_ready=1
      break
    fi
    sleep 1
  done

  if [ "$media_ready" -eq 1 ]; then
    report 'KIOSK_SELFTEST_MEDIA_READY'
    if /usr/local/sbin/kiosk-power-button; then
      report 'KIOSK_SELFTEST_BUTTON_COMMAND_OK'
    else
      report 'KIOSK_SELFTEST_BUTTON_COMMAND_FAIL'
    fi
    switched=0
    for second in $(seq 1 30); do
      if [ "$(cat /run/kiosk-page 2>/dev/null)" = roundview ] \
        && curl -fsS --max-time 2 http://127.0.0.1:9222/json | grep -Fq '192.168.4.1/roundview' \
        && ! mpv_is_running; then
        switched=1
        break
      fi
      sleep 1
    done
    if [ "$switched" -eq 1 ]; then
      report 'KIOSK_SELFTEST_BUTTON_READY'
      report 'KIOSK_SELFTEST_PASS'
      poweroff -f
      exit 0
    fi
  fi
fi

report "KIOSK_SELFTEST_FAIL browser=$ready media=${media_ready:-0} switched=${switched:-0}"
curl -fsS --max-time 2 http://127.0.0.1:9222/json 2>&1 | while IFS= read -r line; do
  report "KIOSK_DIAG CDP $line"
done
for command in \
  'systemctl status kiosk.service --no-pager' \
  'journalctl -u kiosk.service -b --no-pager -n 100' \
  'find /media/kiosk /run/media/kiosk -maxdepth 3 -type f -print' \
  'ps aux'; do
  sh -c "$command" 2>&1 | while IFS= read -r line; do
    report "KIOSK_DIAG $line"
  done
done
for log in /home/kiosk/.local/share/xorg/Xorg.0.log /var/log/Xorg.0.log; do
  if [ -r "$log" ]; then
    report "KIOSK_DIAG --- $log ---"
    tail -n 100 "$log" | while IFS= read -r line; do
      report "KIOSK_DIAG $line"
    done
  fi
done
if [ -r /run/kiosk-selftest-http.log ]; then
  while IFS= read -r line; do
    report "KIOSK_DIAG HTTP $line"
  done < /run/kiosk-selftest-http.log
fi
poweroff -f
exit 1
