#!/bin/sh
set -u

report() {
  printf '<6>%s\n' "$*" > /dev/kmsg
}

report 'KIOSK_SELFTEST_START'

ready=0
for second in $(seq 1 240); do
  if systemctl is-active --quiet kiosk.service \
    && pgrep -x Xorg >/dev/null \
    && pgrep -u kiosk -f '/usr/lib/chromium/chromium|/usr/lib/chromium/chromium-browser' >/dev/null \
    && pgrep -u kiosk -f '/usr/local/bin/kiosk-media-monitor' >/dev/null \
    && curl -fsS --max-time 2 http://127.0.0.1:9222/json | grep -Fq '192.168.4.1/view'; then
    ready=1
    break
  fi
  if systemctl is-failed --quiet kiosk.service; then
    break
  fi
  sleep 1
done

if [ "$ready" -eq 1 ]; then
  report 'KIOSK_SELFTEST_BROWSER_READY'
  media_ready=0
  for second in $(seq 1 90); do
    if pgrep -u kiosk -x mpv >/dev/null; then
      media_ready=1
      break
    fi
    sleep 1
  done

  if [ "$media_ready" -eq 1 ]; then
    report 'KIOSK_SELFTEST_MEDIA_READY'
    /usr/local/sbin/kiosk-power-button
    switched=0
    for second in $(seq 1 30); do
      if [ "$(cat /run/kiosk-page 2>/dev/null)" = roundview ] \
        && curl -fsS --max-time 2 http://127.0.0.1:9222/json | grep -Fq '192.168.4.1/roundview' \
        && ! pgrep -u kiosk -x mpv >/dev/null; then
        switched=1
        break
      fi
      sleep 1
    done
    if [ "$switched" -eq 1 ]; then
      report 'KIOSK_SELFTEST_BUTTON_READY'
      report 'KIOSK_SELFTEST_PASS'
      poweroff -f
      exit 0
    fi
  fi
fi

report "KIOSK_SELFTEST_FAIL browser=$ready media=${media_ready:-0} switched=${switched:-0}"
for command in \
  'systemctl status kiosk.service --no-pager' \
  'journalctl -u kiosk.service -b --no-pager -n 100' \
  'find /media/kiosk /run/media/kiosk -maxdepth 3 -type f -print' \
  'ps aux'; do
  sh -c "$command" 2>&1 | while IFS= read -r line; do
    report "KIOSK_DIAG $line"
  done
done
for log in /home/kiosk/.local/share/xorg/Xorg.0.log /var/log/Xorg.0.log; do
  if [ -r "$log" ]; then
    report "KIOSK_DIAG --- $log ---"
    tail -n 100 "$log" | while IFS= read -r line; do
      report "KIOSK_DIAG $line"
    done
  fi
done
poweroff -f
exit 1
