#!/bin/sh
set -u

report() {
  printf '<6>%s\n' "$*" > /dev/kmsg
}

report 'KIOSK_SELFTEST_START'

emoji_ready=0
if [ -r /usr/share/fonts/truetype/noto/NotoColorEmoji.ttf ]; then
  emoji_ready=1
  report 'KIOSK_SELFTEST_EMOJI_FONT_READY'
else
  report 'KIOSK_SELFTEST_EMOJI_FONT_FAIL'
fi

# Provide a deterministic local stand-in for the ESP32 during the VM test.
ip address add 192.168.4.1/32 dev lo 2>/dev/null || true
/usr/local/sbin/kiosk-selftest-server \
  >/run/kiosk-selftest-http.log 2>&1 &

mpv_is_running() {
  ps -C mpv -o stat= 2>/dev/null | grep -qv '^[[:space:]]*Z'
}

ready=0
for second in $(seq 1 120); do
  if systemctl is-active --quiet kiosk.service \
    && pgrep -x Xorg >/dev/null \
    && pgrep -u kiosk -f '/usr/lib/chromium/chromium|/usr/lib/chromium/chromium-browser' >/dev/null \
    && pgrep -u kiosk -f '/usr/local/bin/kiosk-media-monitor' >/dev/null \
    && [ "$(cat /run/kiosk-chromium/current-url 2>/dev/null)" = 'http://192.168.4.1/view' ]; then
    ready=1
    break
  fi
  if [ $((second % 20)) -eq 0 ]; then
    x=0; chromium=0; monitor=0; cdp=0
    pgrep -x Xorg >/dev/null && x=1
    pgrep -u kiosk -f '/usr/lib/chromium/chromium|/usr/lib/chromium/chromium-browser' >/dev/null && chromium=1
    pgrep -u kiosk -f '/usr/local/bin/kiosk-media-monitor' >/dev/null && monitor=1
    curl -fsS --max-time 1 http://127.0.0.1:9222/json/version >/dev/null && cdp=1
    report "KIOSK_SELFTEST_WAIT second=$second x=$x chromium=$chromium monitor=$monitor cdp=$cdp"
  fi
  if systemctl is-failed --quiet kiosk.service; then
    break
  fi
  sleep 1
done

if [ "$ready" -eq 1 ] && [ "$emoji_ready" -eq 1 ]; then
  report 'KIOSK_SELFTEST_BROWSER_READY'
  if curl -fsS --max-time 2 http://192.168.4.1/roundview >/dev/null; then
    report 'KIOSK_SELFTEST_ROUNDVIEW_HTTP_READY'
  else
    report 'KIOSK_SELFTEST_ROUNDVIEW_HTTP_FAIL'
  fi
  media_ready=0
  for second in $(seq 1 90); do
    if mpv_is_running; then
      media_ready=1
      break
    fi
    sleep 1
  done

  if [ "$media_ready" -eq 1 ]; then
    report 'KIOSK_SELFTEST_MEDIA_READY'
    media_delay=$(cat /run/kiosk-chromium/media-idle-seconds 2>/dev/null || true)
    media_delay_ready=0
    case "$media_delay" in
      ''|*[!0-9]*) ;;
      *)
        if [ "$media_delay" -ge 10 ]; then
          media_delay_ready=1
          report "KIOSK_SELFTEST_MEDIA_DELAY_READY seconds=$media_delay"
        fi
        ;;
    esac

    activity_ready=0
    restart_ready=0
    if [ "$media_delay_ready" -eq 1 ] \
      && /usr/local/bin/kiosk-navigate http://192.168.4.1/roundview; then
      for second in $(seq 1 15); do
        if ! mpv_is_running; then
          activity_ready=1
          report 'KIOSK_SELFTEST_PAGE_ACTIVITY_REVEALS_BROWSER'
          break
        fi
        sleep 1
      done
    fi
    if [ "$activity_ready" -eq 1 ] \
      && /usr/local/bin/kiosk-navigate http://192.168.4.1/view; then
      for second in $(seq 1 30); do
        if mpv_is_running; then
          restart_delay=$(cat /run/kiosk-chromium/media-idle-seconds 2>/dev/null || true)
          case "$restart_delay" in
            ''|*[!0-9]*) ;;
            *)
              if [ "$restart_delay" -ge 10 ]; then
                restart_ready=1
                report "KIOSK_SELFTEST_MEDIA_RESTART_READY seconds=$restart_delay"
              fi
              ;;
          esac
          break
        fi
        sleep 1
      done
    fi

    button_command=0
    if [ "$restart_ready" -eq 1 ] && /usr/local/sbin/kiosk-power-button; then
      button_command=1
      report 'KIOSK_SELFTEST_BUTTON_COMMAND_OK'
    else
      report 'KIOSK_SELFTEST_BUTTON_COMMAND_FAIL'
    fi
    debounced=0
    if [ "$button_command" -eq 1 ] && /usr/local/sbin/kiosk-power-button \
      && [ "$(cat /run/kiosk-page 2>/dev/null)" = roundview ]; then
      debounced=1
      report 'KIOSK_SELFTEST_BUTTON_DEBOUNCE_READY'
    fi
    switched=0
    for second in $(seq 1 30); do
      if [ "$(cat /run/kiosk-page 2>/dev/null)" = roundview ] \
        && [ "$(cat /run/kiosk-chromium/current-url 2>/dev/null)" = 'http://192.168.4.1/roundview' ] \
        && ! mpv_is_running; then
        switched=1
        break
      fi
      sleep 1
    done
    if [ "$switched" -eq 1 ] && [ "$debounced" -eq 1 ]; then
      report 'KIOSK_SELFTEST_BUTTON_READY'
      sleep 3
      if /usr/local/sbin/kiosk-power-button; then
        report 'KIOSK_SELFTEST_BUTTON_TOGGLE_COMMAND_OK'
      else
        report 'KIOSK_SELFTEST_BUTTON_TOGGLE_COMMAND_FAIL'
      fi
      toggled=0
      for second in $(seq 1 30); do
        if [ "$(cat /run/kiosk-page 2>/dev/null)" = view ] \
          && [ "$(cat /run/kiosk-chromium/current-url 2>/dev/null)" = 'http://192.168.4.1/view' ] \
          && ! mpv_is_running; then
          toggled=1
          break
        fi
        sleep 1
      done
      if [ "$toggled" -eq 1 ]; then
        report 'KIOSK_SELFTEST_BUTTON_TOGGLE_READY'
        report 'KIOSK_SELFTEST_PASS'
        poweroff -f
        exit 0
      fi
    fi
  fi
fi

report "KIOSK_SELFTEST_FAIL browser=$ready emoji=$emoji_ready media=${media_ready:-0} delay=${media_delay_ready:-0} activity=${activity_ready:-0} restart=${restart_ready:-0} debounced=${debounced:-0} switched=${switched:-0} toggled=${toggled:-0}"
report "KIOSK_DIAG STATE=$(cat /run/kiosk-page 2>/dev/null || true) CURRENT_URL=$(cat /run/kiosk-chromium/current-url 2>/dev/null || true)"
curl -fsS --max-time 2 http://127.0.0.1:9222/json 2>&1 | while IFS= read -r line; do
  report "KIOSK_DIAG CDP $line"
done
for command in \
  'systemctl status kiosk.service --no-pager' \
  'journalctl -u kiosk.service -b --no-pager -n 100' \
  'find /media/kiosk /run/media/kiosk -maxdepth 3 -type f -print' \
  'ps aux'; do
  sh -c "$command" 2>&1 | while IFS= read -r line; do
    report "KIOSK_DIAG $line"
  done
done
for log in /home/kiosk/.local/share/xorg/Xorg.0.log /var/log/Xorg.0.log; do
  if [ -r "$log" ]; then
    report "KIOSK_DIAG --- $log ---"
    tail -n 100 "$log" | while IFS= read -r line; do
      report "KIOSK_DIAG $line"
    done
  fi
done
if [ -r /run/kiosk-selftest-http.log ]; then
  while IFS= read -r line; do
    report "KIOSK_DIAG HTTP $line"
  done < /run/kiosk-selftest-http.log
fi
poweroff -f
exit 1
