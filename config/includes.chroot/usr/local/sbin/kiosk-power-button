#!/bin/sh
set -eu
STATE=/run/kiosk-page
LOCK=/run/kiosk-power-button.lock
STAMP=/run/kiosk-power-button.last

exec 9>"$LOCK"
flock -n 9 || exit 0

NOW=$(cut -d. -f1 /proc/uptime)
LAST=$(cat "$STAMP" 2>/dev/null || true)
case "$LAST" in
  ''|*[!0-9]*) LAST=0 ;;
esac
if [ $((NOW - LAST)) -lt 2 ]; then
  exit 0
fi
trap 'cut -d. -f1 /proc/uptime > "$STAMP"' EXIT

URL=http://192.168.4.1/roundview
if [ "$(cat "$STATE" 2>/dev/null || true)" = roundview ]; then
  URL=http://192.168.4.1/view
  printf '%s\n' view > "$STATE"
else
  printf '%s\n' roundview > "$STATE"
fi

# Reveal the browser immediately and navigate its existing tab directly. The
# keyboard fallback is retained for the unlikely case that Chromium's local
# debugging endpoint is temporarily unavailable.
touch /run/kiosk-chromium/force-browser 2>/dev/null || true
pkill -u kiosk -x mpv 2>/dev/null || true
if /usr/local/bin/kiosk-navigate "$URL"; then
  exit 0
fi
export DISPLAY=:0
WINDOW=$(xdotool search --onlyvisible --class 'chromium' 2>/dev/null | tail -n 1)
[ -n "$WINDOW" ]
xdotool windowactivate --sync "$WINDOW"
xdotool key --window "$WINDOW" --clearmodifiers ctrl+l
xdotool type --window "$WINDOW" --delay 1 "$URL"
xdotool key --window "$WINDOW" Return
