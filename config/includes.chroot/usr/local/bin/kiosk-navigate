#!/usr/bin/python3
import asyncio
import json
import pathlib
import sys
import urllib.request

import websockets

CURRENT_URL = pathlib.Path("/run/kiosk-chromium/current-url")


async def command(socket, command_id, method, params=None):
    request = {"id": command_id, "method": method}
    if params is not None:
        request["params"] = params
    await socket.send(json.dumps(request))
    while True:
        reply = json.loads(await asyncio.wait_for(socket.recv(), timeout=5))
        if reply.get("id") != command_id:
            continue
        if "error" in reply:
            raise RuntimeError(reply["error"])
        return reply.get("result", {})


async def navigate(url):
    with urllib.request.urlopen("http://127.0.0.1:9222/json", timeout=3) as response:
        targets = json.load(response)
    page = next(target for target in targets if target.get("type") == "page")

    async with websockets.connect(page["webSocketDebuggerUrl"], max_size=1024 * 1024) as socket:
        result = await command(socket, 1, "Page.navigate", {"url": url})
        if result.get("errorText"):
            raise RuntimeError(result["errorText"])

        # Keep the debugger attached until the provisional navigation has
        # committed. This avoids an empty page on slow, low-power hardware.
        for attempt in range(2, 42):
            await asyncio.sleep(0.25)
            result = await command(socket, attempt, "Runtime.evaluate", {
                "expression": "window.location.href",
                "returnByValue": True,
            })
            current = result.get("result", {}).get("value")
            if current == url:
                CURRENT_URL.write_text(f"{url}\n", encoding="utf-8")
                return
        raise RuntimeError("navigation did not commit")


if __name__ == "__main__":
    if len(sys.argv) != 2 or not sys.argv[1].startswith("http://192.168.4.1/"):
        raise SystemExit(2)
    asyncio.run(navigate(sys.argv[1]))
