#!/usr/bin/python3
import asyncio
import base64
import hashlib
import io
import json
import os
import pathlib
import signal
import subprocess
import time
import urllib.request

from PIL import Image, ImageChops
import websockets

CMDLINE = pathlib.Path("/proc/cmdline").read_text(encoding="utf-8", errors="ignore")
IDLE_SECONDS = 10 if "kiosk.selftest=1" in CMDLINE else 240
POLL_SECONDS = 2
SCREENSHOT_SIZE = (160, 90)
PIXEL_CHANGE_THRESHOLD = 4
MIN_CHANGED_PIXELS = 3
MEDIA_EXTENSIONS = {
    ".jpg", ".jpeg", ".png", ".webp", ".bmp", ".gif", ".heic", ".heif",
    ".mp4", ".m4v", ".mov", ".mkv", ".avi", ".webm", ".mpeg", ".mpg",
}
MEDIA_ROOTS = (pathlib.Path("/media/kiosk"), pathlib.Path("/run/media/kiosk"))
HEIF_EXTENSIONS = {".heic", ".heif"}
RUNTIME_DIR = pathlib.Path("/run/kiosk-chromium")
HEIF_CACHE = RUNTIME_DIR / "heif"
FORCE_BROWSER = RUNTIME_DIR / "force-browser"
MEDIA_IDLE_FILE = RUNTIME_DIR / "media-idle-seconds"


def browser_socket():
    with urllib.request.urlopen("http://127.0.0.1:9222/json", timeout=2) as response:
        pages = json.load(response)
    page = next(item for item in pages if item.get("type") == "page")
    return page["webSocketDebuggerUrl"]


async def capture_page():
    async with websockets.connect(browser_socket(), max_size=8 * 1024 * 1024) as socket:
        await socket.send(json.dumps({
            "id": 1,
            "method": "Runtime.evaluate",
            "params": {
                "expression": "document.body ? document.body.innerText : ''",
                "returnByValue": True,
            },
        }))
        while True:
            reply = json.loads(await socket.recv())
            if reply.get("id") == 1:
                body_text = reply.get("result", {}).get("result", {}).get("value", "")
                break

        await socket.send(json.dumps({
            "id": 2,
            "method": "Page.captureScreenshot",
            "params": {"format": "png", "captureBeyondViewport": False},
        }))
        while True:
            reply = json.loads(await socket.recv())
            if reply.get("id") == 2:
                raw = base64.b64decode(reply["result"]["data"])
                image = Image.open(io.BytesIO(raw)).convert("L").resize(SCREENSHOT_SIZE)
                return body_text, image


def page_changed(first, second):
    first_text, first_image = first
    second_text, second_image = second
    if first_text != second_text:
        return True
    histogram = ImageChops.difference(first_image, second_image).histogram()
    changed_pixels = sum(histogram[PIXEL_CHANGE_THRESHOLD + 1:])
    return changed_pixels >= MIN_CHANGED_PIXELS


def converted_heif(item):
    try:
        stat = item.stat()
        identity = f"{item.resolve()}:{stat.st_size}:{stat.st_mtime_ns}"
        target = HEIF_CACHE / f"{hashlib.sha256(identity.encode()).hexdigest()}.jpg"
        if not target.exists():
            HEIF_CACHE.mkdir(mode=0o700, parents=True, exist_ok=True)
            subprocess.run(
                ["heif-convert", "-q", "85", str(item), str(target)],
                check=True,
                timeout=60,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        return str(target)
    except (OSError, subprocess.SubprocessError):
        return None


def media_files():
    found = []
    for root in MEDIA_ROOTS:
        if not root.exists():
            continue
        for item in root.rglob("*"):
            try:
                suffix = item.suffix.lower()
                if item.is_file() and suffix in MEDIA_EXTENSIONS:
                    if suffix in HEIF_EXTENSIONS:
                        converted = converted_heif(item)
                        if converted:
                            found.append(converted)
                    else:
                        found.append(str(item))
            except OSError:
                pass
    return sorted(found)


def media_signature(files):
    signature = []
    for name in files:
        try:
            stat = pathlib.Path(name).stat()
            signature.append((name, stat.st_size, stat.st_mtime_ns))
        except OSError:
            signature.append((name, 0, 0))
    return tuple(signature)


def start_player(files):
    playlist = RUNTIME_DIR / "media-playlist.txt"
    playlist.write_text("".join(f"{name}\n" for name in files), encoding="utf-8")
    return subprocess.Popen([
        "mpv", "--fullscreen", "--no-border", "--ontop", "--really-quiet",
        "--hwdec=auto-safe", "--image-display-duration=8", "--loop-playlist=inf",
        "--shuffle", f"--playlist={playlist}",
    ])


def stop_player(player):
    if player and player.poll() is None:
        player.terminate()
        try:
            player.wait(timeout=3)
        except subprocess.TimeoutExpired:
            player.kill()


async def main():
    previous = None
    previous_media = None
    last_change = time.monotonic()
    last_force = None
    player = None
    while True:
        try:
            current_force = FORCE_BROWSER.stat().st_mtime_ns
        except OSError:
            current_force = 0
        if current_force != last_force:
            last_force = current_force
            last_change = time.monotonic()
            stop_player(player)
            player = None

        try:
            current = await capture_page()
            if previous is None or page_changed(previous, current):
                last_change = time.monotonic()
                stop_player(player)
                player = None
            previous = current
        except Exception:
            pass

        files = media_files()
        current_media = media_signature(files)
        if current_media != previous_media:
            previous_media = current_media
            last_change = time.monotonic()
            stop_player(player)
            player = None

        if not files:
            stop_player(player)
            player = None
        elif time.monotonic() - last_change >= IDLE_SECONDS:
            if player is None or player.poll() is not None:
                MEDIA_IDLE_FILE.write_text(
                    f"{int(time.monotonic() - last_change)}\n", encoding="utf-8"
                )
                player = start_player(files)

        await asyncio.sleep(POLL_SECONDS)


if __name__ == "__main__":
    asyncio.run(main())
