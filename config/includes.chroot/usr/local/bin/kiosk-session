#!/bin/sh
set -eu
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ]; then
  exec dbus-run-session -- "$0"
fi
xset -dpms
xset s off
xset s noblank
xhost +SI:localuser:root +SI:localuser:kiosk
unclutter -idle 0.3 -root &
openbox-session &
udiskie --automount --no-notify --no-tray &
find /run/kiosk-chromium -mindepth 1 -delete
install -d -m 0700 /run/kiosk-chromium
printf '%s\n' view > /run/kiosk-page
chromium \
  --kiosk \
  --no-first-run \
  --no-default-browser-check \
  --noerrdialogs \
  --password-store=basic \
  --disable-session-crashed-bubble \
  --disable-infobars \
  --disable-translate \
  --disable-features=Translate,MediaRouter,OptimizationHints \
  --disable-component-update \
  --disk-cache-size=1 \
  --remote-debugging-address=127.0.0.1 \
  --remote-debugging-port=9222 \
  --remote-allow-origins=* \
  --disable-background-timer-throttling \
  --disable-renderer-backgrounding \
  --user-data-dir=/run/kiosk-chromium \
  --start-fullscreen \
  http://192.168.4.1/view &
BROWSER_PID=$!

# Chromium does not always retain an initial failed URL. Navigate explicitly
# when the ESP32 becomes reachable after startup or after a disconnect.
(
  ONLINE=0
  while sleep 5; do
    if curl -fsS --max-time 2 http://192.168.4.1/view >/dev/null 2>&1; then
      TARGET=http://192.168.4.1/view
      if [ "$(cat /run/kiosk-page 2>/dev/null || true)" = roundview ]; then
        TARGET=http://192.168.4.1/roundview
      fi
      CURRENT=$(cat /run/kiosk-chromium/current-url 2>/dev/null || true)
      if [ "$ONLINE" -eq 0 ] || [ "$CURRENT" != "$TARGET" ]; then
        touch /run/kiosk-chromium/force-browser 2>/dev/null || true
        pkill -x mpv 2>/dev/null || true
        if ! /usr/local/bin/kiosk-navigate "$TARGET" >/dev/null 2>&1; then
          WINDOW=$(xdotool search --onlyvisible --class 'chromium' 2>/dev/null | tail -n 1 || true)
          if [ -n "$WINDOW" ]; then
            xdotool windowactivate --sync "$WINDOW" >/dev/null 2>&1 || true
            xdotool key --window "$WINDOW" --clearmodifiers ctrl+l >/dev/null 2>&1 || true
            xdotool type --window "$WINDOW" --delay 1 "$TARGET" >/dev/null 2>&1 || true
            xdotool key --window "$WINDOW" Return >/dev/null 2>&1 || true
          fi
        fi
      fi
      ONLINE=1
    else
      ONLINE=0
    fi
  done
) &

(
  while true; do
    /usr/local/bin/kiosk-media-monitor || true
    sleep 2
  done
) &
wait "$BROWSER_PID"
